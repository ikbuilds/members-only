<main class="max-w-2xl mx-auto px-6 py-10 animate-fade-up-blur">

  <header class="mb-8">
    <h1 class="font-heading text-headline-md font-extrabold text-on-surface">
      Create Message
    </h1>
    <p class="text-body-md text-on-surface-variant mt-1">
      Share something with the community.
    </p>
  </header>

  <form action="/messages/new" method="POST" class="border border-outline bg-surface-container rounded-2xl p-6 space-y-6">

    <%# Title  %>
    <div>
      <label class="block text-label-lg text-on-surface-variant mb-2">
        Title
      </label>

      <input name="title" type="text" value="<%= data?.title || '' %>" placeholder="Enter a title..." class="w-full px-4 py-3 rounded-xl border text-on-surface placeholder:text-on-surface-variant focus:outline-none focus:ring-2 focus:ring-primary
        <% if (errors?.title) { %>
          border-error
        <% } else { %>
          border-outline bg-surface-container-high
        <% } %>" />

      <% if (errors?.title) { %>
      <p class="mt-2 text-label-sm text-error">
        <%= errors.title.msg %>
      </p>
      <% } %>
    </div>

    <%# Message %>
    <div>
      <label class="block text-label-lg text-on-surface-variant mb-2">
        Content
      </label>

      <textarea name="content" rows="6" placeholder="Write your message..." class="w-full px-4 py-3 rounded-xl border text-on-surface placeholder:text-on-surface-variant focus:outline-none focus:ring-2 focus:ring-primary resize-none
        <% if (errors?.content) { %>
          border-error
        <% } else { %>
          border-outline bg-surface-container-high
        <% } %>"><%= data?.content || '' %></textarea>

      <% if (errors?.content) { %>
      <p class="mt-2 text-label-sm text-error">
        <%= errors.content.msg %>
      </p>
      <% } %>
    </div>

    <%# Actions  %>
    <div class="flex items-center justify-between pt-2">

      <a href="/messages" class="text-body-sm text-on-surface-variant hover:text-on-surface transition-colors">
        Cancel
      </a>

      <button type="submit" class="px-5 py-2 rounded-full bg-primary text-on-primary font-semibold hover:opacity-90 transition-opacity">
        Post Message
      </button>

    </div>

  </form>

</main>