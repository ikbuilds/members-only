<%- include("../partials/header") %>

<main class="flex items-center justify-center px-5 py-16">

  <section class="w-full max-w-md bg-surface-container rounded-3xl p-8 border border-outline shadow-lg animate-fade-up-blur">

    <%# HEADER %>
    <header class="text-center mb-8">
      <h1 class="text-3xl font-heading font-black text-on-surface">
        Become a Member
      </h1>

      <p class="mt-2 text-on-surface-variant">
        Enter your invitation code to unlock member access.
      </p>
    </header>

    <%# ERROR %>
    <% if (codeError) { %>
    <div class="mb-5 px-4 py-3 rounded-xl bg-error-container text-on-error-container border border-error">
      <%= codeError.msg %>
    </div>
    <% } %>

    <%# FORM %>
    <form action="/membership/join" method="POST" class="space-y-5">

      <div>
        <label class="block text-sm mb-2 text-on-surface-variant">
          Invitation Code
        </label>

        <input type="text" name="code" placeholder="Enter your code" class="w-full px-4 py-3 rounded-xl bg-surface-container-high text-on-surface border border-outline outline-none focus:border-primary" />
      </div>

      <button type="submit" class="w-full py-3 rounded-xl bg-primary text-on-primary font-semibold hover:opacity-90 transition">
        Unlock Membership
      </button>

    </form>

    <%# CANCEL ACTION %>
    <div class="mt-6 text-center">
      <a href="/messages" class="text-sm text-on-surface-variant hover:text-on-surface transition">
        Cancel
      </a>
    </div>

  </section>

</main>